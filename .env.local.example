# Copy to .env.local and fill in. Never commit .env.local.

# App auth (single password gate, HMAC-signed cookie)
AUTH_PASSWORD=
AUTH_SECRET=

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Vercel KV (auto-populated by `vercel env pull` after linking the KV store)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Vercel Blob (auto-populated by `vercel env pull`)
BLOB_READ_WRITE_TOKEN=
